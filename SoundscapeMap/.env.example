NODE_ENV=development
PUBLIC_WEB_ORIGIN=http://127.0.0.1:5173
API_PORT=18080
REGION_SERVICE_URL=http://localhost:8090
OPENAI_API_KEY=
OPENAI_DESCRIPTOR_MODEL=gpt-4.1-mini

SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:5173/callback
JWT_SECRET=replace-with-256-bit-random-secret

DATABASE_URL=postgresql://soundscape:soundscape@localhost:5432/soundscape

IPAPI_KEY=

# Frontend Vite variables
VITE_API_BASE=http://127.0.0.1:18080
VITE_WS_URL=ws://127.0.0.1:18080/ws
VITE_GOOGLE_MAPS_API_KEY=
VITE_GOOGLE_MAP_ID=
VITE_GOOGLE_3D_TILES_KEY=
VITE_ENABLE_GOOGLE_3D=true

ENABLE_AUTO_VOTE=true
MAX_CELLS_PER_SUBSCRIPTION=50

REGION_MODEL=fixed_h3
CLUSTER_MIN_SIZE=5
CLUSTER_SPATIAL_WEIGHT=0.3
CLUSTER_RECOMPUTE_INTERVAL=300
CLUSTER_FALLBACK_ON_DEGRADATION=true
