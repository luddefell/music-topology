NODE_ENV=development
PUBLIC_WEB_ORIGIN=http://localhost:5173
API_PORT=8080
REGION_SERVICE_URL=http://localhost:8090

SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:5173/callback
JWT_SECRET=replace-with-256-bit-random-secret
REFRESH_TOKEN_ENCRYPTION_KEY=replace-with-32-byte-base64-key

DATABASE_URL=postgresql://soundscape:soundscape@localhost:5432/soundscape
REDIS_URL=redis://localhost:6379

MAPTILER_API_KEY=
IPAPI_KEY=

ENABLE_AUTO_VOTE=true
MAX_CELLS_PER_SUBSCRIPTION=50

REGION_MODEL=fixed_h3
CLUSTER_MIN_SIZE=5
CLUSTER_SPATIAL_WEIGHT=0.3
CLUSTER_RECOMPUTE_INTERVAL=300
CLUSTER_FALLBACK_ON_DEGRADATION=true
