{
  "name": "soundscapemap",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/web",
    "packages/shared"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:web dev:api dev:region",
    "dev:web": "npm --workspace apps/web run dev",
    "dev:api": "./mvnw -f services/api-spring/pom.xml spring-boot:run",
    "dev:region": "python3 -m uvicorn services.region.app.main:app --reload --port 8090",
    "build": "npm --workspace packages/shared run build && ./mvnw -f services/api-spring/pom.xml -DskipTests package && npm --workspace apps/web run build",
    "lint": "npm --workspace packages/shared run lint && npm --workspace apps/web run lint",
    "test": "node --test packages/shared/test/*.test.mjs",
    "smoke": "node scripts/smoke-test.mjs",
    "integration:vote": "node scripts/integration-vote-flow.mjs"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
